{
  "name": "@octomil/sdk",
  "version": "1.5.6",
  "description": "Octomil Node.js SDK for hosted and local AI inference",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run --json",
    "exports:check": "node -e 'import(\"./dist/esm/index.js\").then((m)=>{for (const name of [\"Octomil\",\"OctomilClient\",\"ResponsesClient\"]) if (typeof m[name] !== \"function\") throw new Error(`${name} export missing`)})'",
    "prepublishOnly": "pnpm run typecheck && pnpm test && pnpm run build && pnpm run exports:check && pnpm run pack:check",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "koffi": "^2.16.2",
    "onnxruntime-node": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.4.0",
    "esbuild": "^0.20.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/octomil/octomil-node.git"
  }
}
